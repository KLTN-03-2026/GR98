generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("RefreshTokens")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("PasswordResets")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  passwordHash      String
  fullName          String
  phone             String?
  avatar            String?
  role              Role
  status            UserStatus         @default(ACTIVE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  adminProfile      AdminProfile?
  clientProfile     ClientProfile?
  inventoryProfile  InventoryProfile?
  shipperProfile    ShipperProfile?
  passwordResets    PasswordReset[]
  refreshToken      RefreshToken?
  supervisorProfile SupervisorProfile?

  @@map("users")
}

model AdminProfile {
  id               String              @id @default(cuid())
  userId           String              @unique
  businessName     String
  taxCode          String?
  bankAccount      String?
  province         String
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments      Assignment[]
  contracts        Contract[]
  farmers          Farmer[]
  inventoryStaff   InventoryProfile[]
  shippers         ShipperProfile[]
  orders           Order[]
  plantScanRecords PlantScanRecord[]
  plots            Plot[]
  priceBoards      PriceBoard[]
  products         Product[]
  supervisors      SupervisorProfile[]
  zones            Zone[]
  warehouses       Warehouse[]
  scanSessions     ScanSession[]
  recommendations  TreatmentRecommendation[]

  @@map("AdminProfiles")
}

model InventoryProfile {
  id           String       @id @default(cuid())
  userId       String       @unique
  adminId      String
  employeeCode String       @unique
  hiredAt      DateTime     @default(now())
  admin        AdminProfile @relation(fields: [adminId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouses   Warehouse[]

  @@map("InventoryProfiles")
}

model SupervisorProfile {
  id               String            @id @default(cuid())
  userId           String            @unique
  adminId          String
  zoneId           String?
  employeeCode     String            @unique
  hiredAt          DateTime          @default(now())
  lat              Float?
  lng              Float?
  lastSeenAt       DateTime?
  assignments      Assignment[]
  contracts        Contract[]
  dailyReports     DailyReport[]
  farmers          Farmer[]
  plantScanRecords PlantScanRecord[]
  scanSessions     ScanSession[]
  admin            AdminProfile      @relation(fields: [adminId], references: [id])
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  zone             Zone?             @relation(fields: [zoneId], references: [id])

  @@map("SupervisorProfiles")
}

model ClientProfile {
  id                String                  @id @default(cuid())
  userId            String                  @unique
  adminId           String?
  province          String?
  createdAt         DateTime                @default(now())
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingAddresses ClientShippingAddress[]
  orders            Order[]
  reviews           Review[]
  cart              Cart?

  @@map("ClientProfiles")
}

model ShipperProfile {
  id           String        @id @default(cuid())
  userId       String        @unique
  adminId      String
  employeeCode String        @unique
  hiredAt      DateTime      @default(now())
  lat          Float?
  lng          Float?
  lastSeenAt   DateTime?
  vehicleType  VehicleType   @default(MOTORBIKE)
  licensePlate String?
  status       ShipperStatus @default(AVAILABLE)
  admin        AdminProfile  @relation(fields: [adminId], references: [id])
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries   Order[]

  @@map("ShipperProfiles")
}

model Cart {
  id        String        @id @default(cuid())
  clientId  String        @unique
  updatedAt DateTime      @updatedAt
  createdAt DateTime      @default(now())
  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@map("Carts")
}

model CartItem {
  id         String   @id @default(cuid())
  cartId     String
  productId  String
  quantityKg Float
  addedAt    DateTime @default(now())
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("CartItems")
}

model ClientShippingAddress {
  id              String        @id @default(cuid())
  clientProfileId String
  fullName        String
  phone           String
  addressLine     String
  district        String?
  province        String
  addressType     AddressType   @default(HOME)
  isDefault       Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([clientProfileId])
  @@map("ClientShippingAddresses")
}

model Zone {
  id          String              @id @default(cuid())
  adminId     String
  name        String
  province    String
  district    String
  centerLat   Float?
  centerLng   Float?
  totalAreaHa Float               @default(0)
  plots       Plot[]
  supervisors SupervisorProfile[]
  admin       AdminProfile        @relation(fields: [adminId], references: [id])

  @@map("Zones")
}

model Farmer {
  id           String             @id @default(cuid())
  adminId      String
  fullName     String
  phone        String
  cccd         String             @unique
  bankAccount  String?
  bankName     String?
  bankBranch   String?
  address      String?
  province     String?
  status       FarmerStatus       @default(ACTIVE)
  createdAt    DateTime           @default(now())
  supervisorId String?
  contracts    Contract[]
  admin        AdminProfile       @relation(fields: [adminId], references: [id])
  supervisor   SupervisorProfile? @relation(fields: [supervisorId], references: [id])
  plots        Plot[]

  @@map("Farmers")
}

model Plot {
  id               String            @id @default(cuid())
  farmerId         String
  adminId          String
  zoneId           String?
  plotCode         String            @unique
  cropType         String
  areaHa           Float
  lat              Float?
  lng              Float?
  status           PlotStatus        @default(ACTIVE)
  plantingDate     DateTime?
  expectedHarvest  DateTime?
  estimatedYieldKg Float?
  createdAt        DateTime          @default(now())
  assignments      Assignment[]
  contracts        Contract[]
  dailyReports     DailyReport[]
  plantScanRecords PlantScanRecord[]
  scanSessions     ScanSession[]
  admin            AdminProfile      @relation(fields: [adminId], references: [id])
  farmer           Farmer            @relation(fields: [farmerId], references: [id])
  zone             Zone?             @relation(fields: [zoneId], references: [id])
  products         Product[]

  @@map("Plots")
}

model Assignment {
  id           String            @id @default(cuid())
  supervisorId String
  plotId       String
  adminId      String
  status       AssignStatus      @default(PENDING)
  assignedAt   DateTime          @default(now())
  dueDate      DateTime?
  note         String?
  admin        AdminProfile      @relation(fields: [adminId], references: [id])
  plot         Plot              @relation(fields: [plotId], references: [id])
  supervisor   SupervisorProfile @relation(fields: [supervisorId], references: [id])

  @@map("Assignments")
}

model DailyReport {
  id                      String                   @id @default(cuid())
  supervisorId            String
  plotId                  String
  adminId                 String
  type                    ReportType               @default(ROUTINE)
  content                 String
  imageUrls               String[]
  isSynced                Boolean                  @default(false)
  reportedAt              DateTime                 @default(now())
  syncedAt                DateTime?
  status                  ReportStatus             @default(DRAFT)
  aiVisionResult          Json?
  yieldEstimateKg         Float?
  /// Workflow xử lý sự cố — chỉ áp dụng cho báo cáo loại INCIDENT.
  incidentHandlingStatus  IncidentHandlingStatus?
  /// Ghi chú của Admin khi cập nhật trạng thái xử lý (tên chuyên gia, kết quả...).
  incidentHandlingNote    String?
  /// Thời điểm Admin cập nhật trạng thái xử lý lần cuối.
  incidentHandledAt       DateTime?
  plot                    Plot                     @relation(fields: [plotId], references: [id])
  supervisor              SupervisorProfile        @relation(fields: [supervisorId], references: [id])

  @@map("DailyReports")
}

model PriceBoard {
  id            String       @id @default(cuid())
  adminId       String
  cropType      String
  grade         QualityGrade
  buyPrice      Float
  sellPrice     Float
  effectiveDate DateTime     @default(now())
  isActive      Boolean      @default(true)
  admin         AdminProfile @relation(fields: [adminId], references: [id])

  @@map("PriceBoards")
}

model Contract {
  id                       String            @id @default(cuid())
  adminId                  String
  supervisorId             String
  farmerId                 String
  plotId                   String?
  contractNo               String            @unique
  cropType                 String
  variety                  String?
  grade                    QualityGrade
  status                   ContractStatus    @default(DRAFT)
  signedAt                 DateTime?
  harvestDue               DateTime?
  signatureUrl             String?
  traceabilityQr           String?
  submittedAt              DateTime?
  approvedAt               DateTime?
  approvedBy               String?
  rejectedReason           String?
  plotDraftProvince        String?
  plotDraftDistrict        String?
  plotDraftAreaHa          Float?
  plotDraftCoordinatesText String?
  createdAt                DateTime          @default(now())
  admin                    AdminProfile      @relation(fields: [adminId], references: [id])
  farmer                   Farmer            @relation(fields: [farmerId], references: [id])
  plot                     Plot?             @relation(fields: [plotId], references: [id])
  supervisor               SupervisorProfile @relation(fields: [supervisorId], references: [id])
  product                  Product?
  inventoryLots            InventoryLot[]

  @@map("Contracts")
}

model Product {
  id                String                 @id @default(cuid())
  adminId           String
  plotId            String?
  contractId        String?                @unique
  name              String
  slug              String                 @unique
  sku               String                 @unique
  description       String?
  cropType          String
  variety           String?
  grade             QualityGrade
  pricePerKg        Float
  stockKg           Float                  @default(0)
  reservedKg        Float                  @default(0)
  minOrderKg        Float                  @default(1)
  unit              String                 @default("kg")
  qrCode            String                 @unique
  imageUrls         String[]
  thumbnailUrl      String?
  status            ProductStatus          @default(DRAFT)
  harvestDate       DateTime?
  aiConfidenceScore Float?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  orderItems        OrderItem[]
  cartItems         CartItem[]
  categories        ProductCategory[]
  admin             AdminProfile           @relation(fields: [adminId], references: [id])
  contract          Contract?              @relation(fields: [contractId], references: [id])
  plot              Plot?                  @relation(fields: [plotId], references: [id])
  reviews           Review[]
  inventoryLots     InventoryLot[]
  transactions      WarehouseTransaction[]

  @@map("Products")
}

model Category {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  imageUrl    String?
  isActive    Boolean           @default(true)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  products    ProductCategory[]

  @@map("Categories")
}

model ProductCategory {
  productId  String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("ProductCategories")
}

model Order {
  id               String          @id @default(cuid())
  clientId         String
  adminId          String
  shipperId        String?
  orderNo          String          @unique
  orderCode        String          @unique
  subtotal         Float
  shippingFee      Float           @default(0)
  discount         Float           @default(0)
  total            Float
  paymentMethod    PaymentMethod
  paymentRef       String?
  paymentStatus    PaymentStatus   @default(PENDING)
  fulfillStatus    FulfillStatus   @default(PENDING)
  shippingAddr     Json
  shippingAddrText String?
  trackingCode     String?
  deliveryProofUrl String?
  note             String?
  orderedAt        DateTime        @default(now())
  paidAt           DateTime?
  packedAt         DateTime?
  shippedAt        DateTime?
  deliveredAt      DateTime?
  cancelledAt      DateTime?
  cancelReason     String?
  orderItems       OrderItem[]
  admin            AdminProfile    @relation(fields: [adminId], references: [id])
  client           ClientProfile   @relation(fields: [clientId], references: [id])
  shipper          ShipperProfile? @relation(fields: [shipperId], references: [id])

  @@map("Orders")
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  productId     String
  nameSnapshot  String
  priceSnapshot Float
  quantityKg    Float
  subtotal      Float
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product @relation(fields: [productId], references: [id])

  @@map("OrderItems")
}

model Review {
  id               String        @id @default(cuid())
  productId        String
  clientId         String
  rating           Int
  comment          String?
  imageUrls        String[]
  verifiedPurchase Boolean       @default(false)
  status           ReviewStatus  @default(PENDING)
  createdAt        DateTime      @default(now())
  client           ClientProfile @relation(fields: [clientId], references: [id])
  product          Product       @relation(fields: [productId], references: [id])

  @@map("Reviews")
}

model Warehouse {
  id              String                 @id @default(cuid())
  name            String
  locationAddress String?
  isActive        Boolean                @default(true)
  capacityKg      Float?
  createdAt       DateTime               @default(now())
  managedBy       String?
  adminId         String
  inventoryLots   InventoryLot[]
  transactions    WarehouseTransaction[]
  admin           AdminProfile           @relation(fields: [adminId], references: [id])
  inventory       InventoryProfile?      @relation(fields: [managedBy], references: [id])

  @@map("warehouses")
}

model InventoryLot {
  id           String                 @id @default(cuid())
  warehouseId  String
  productId    String
  contractId   String?
  quantityKg   Float
  harvestDate  DateTime?
  expiryDate   DateTime?
  qualityGrade QualityGrade
  status       InventoryLotStatus     @default(SCHEDULED)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  contract     Contract?              @relation(fields: [contractId], references: [id])
  product      Product                @relation(fields: [productId], references: [id])
  warehouse    Warehouse              @relation(fields: [warehouseId], references: [id])
  transactions WarehouseTransaction[]

  @@map("inventory_lots")
}

model WarehouseTransaction {
  id             String            @id @default(cuid())
  warehouseId    String
  productId      String
  inventoryLotId String
  quantityKg     Float
  note           String?
  createdBy      String
  createdAt      DateTime          @default(now())
  action         TransactionAction
  type           TransactionType
  inventoryLot   InventoryLot      @relation(fields: [inventoryLotId], references: [id])
  product        Product           @relation(fields: [productId], references: [id])
  warehouse      Warehouse         @relation(fields: [warehouseId], references: [id])

  @@map("warehouse_transactions")
}

model PlantScanRecord {
  id           String            @id @default(uuid())
  adminId      String
  supervisorId String
  plotId       String?
  sessionId    String?
  diseaseEn    String
  diseaseVi    String
  causingAgent String
  dangerLevel  String
  category     String
  symptoms     String
  treatment    String
  confidence   Float
  processingMs Float?
  imageDataUrl String?
  scannedAt    DateTime          @default(now())
  admin        AdminProfile      @relation(fields: [adminId], references: [id])
  plot         Plot?             @relation(fields: [plotId], references: [id])
  supervisor   SupervisorProfile @relation(fields: [supervisorId], references: [id])
  session      ScanSession?      @relation(fields: [sessionId], references: [id])

  @@index([adminId])
  @@index([supervisorId])
  @@index([scannedAt])
  @@index([sessionId])
  @@map("PlantScanRecords")
}

/// Phiên quét đa điểm — supervisor đi quanh 1 lô, chụp nhiều cây trong 1
/// phiên. Khi đóng phiên, hệ thống tổng hợp tỉ lệ cây nhiễm theo từng loại
/// bệnh và đưa ra severity ở cấp lô (light/medium/severe) để làm input cho
/// AI advisor đưa khuyến nghị xử lý.
model ScanSession {
  id             String            @id @default(cuid())
  adminId        String
  supervisorId   String
  plotId         String
  status         ScanSessionStatus @default(OPEN)
  startedAt      DateTime          @default(now())
  closedAt       DateTime?
  totalScans     Int               @default(0)
  infectedCount  Int               @default(0)
  severity       String? // 'light' | 'medium' | 'severe'
  /// JSON tóm tắt số ảnh theo từng loại bệnh, vd:
  /// { "Phytophthora": 6, "Anthracnose": 2, "Healthy": 4 }
  diseaseSummary Json?
  note           String?

  admin        AdminProfile      @relation(fields: [adminId], references: [id])
  plot         Plot              @relation(fields: [plotId], references: [id])
  supervisor   SupervisorProfile @relation(fields: [supervisorId], references: [id])
  scans        PlantScanRecord[]
  /// 1 phiên có thể có nhiều recommendation (vd. admin từ chối lần 1 → tạo lại).
  recommendations TreatmentRecommendation[]

  @@index([adminId])
  @@index([plotId])
  @@index([supervisorId])
  @@index([status])
  @@map("ScanSessions")
}

enum ScanSessionStatus {
  OPEN
  CLOSED
  REVIEWED
  CANCELLED
}

/// Khuyến nghị xử lý cấp lô do AI Advisor sinh ra từ 1 phiên quét đã đóng.
/// Luôn ở trạng thái DRAFT lúc tạo — supervisor/kỹ sư phải APPROVE/REJECT
/// thủ công trước khi áp dụng. Lưu đầy đủ payload + citations để audit.
model TreatmentRecommendation {
  id            String   @id @default(cuid())
  sessionId     String
  adminId       String
  /// Phân hạng AI tự tin với khuyến nghị: 'high' | 'medium' | 'low'.
  /// Nếu 'low' → BE chặn không cho APPROVE, yêu cầu hỏi kỹ sư.
  confidence    String?
  /// JSON payload từ Claude: { product, dosagePerHa, totalDosage,
  /// sprayInterval, duration, warnings, ... }
  payload       Json
  /// Citations từ tài liệu BVTV — bắt buộc có ≥1, dùng để chống hallucination.
  /// Lưu để audit khi user bấm "Xem nguồn tham khảo".
  citations     Json
  status        RecommendationStatus @default(DRAFT)
  createdAt     DateTime @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?
  /// Ghi chú khi duyệt/từ chối, hoặc ghi rõ supervisor đã sửa liều gì.
  reviewNote    String?

  session ScanSession @relation(fields: [sessionId], references: [id])
  admin   AdminProfile @relation(fields: [adminId], references: [id])

  @@index([sessionId])
  @@index([status])
  @@map("TreatmentRecommendations")
}

enum RecommendationStatus {
  DRAFT
  APPROVED
  REJECTED
}

/// Chunk văn bản nhỏ (~500 từ) cắt ra từ tài liệu BVTV (PDF). Dùng cho RAG —
/// AI Advisor sẽ retrieve top-K chunk liên quan đến câu truy vấn (vd. "thán
/// thư cà phê liều lượng"), kèm vào prompt Claude để chống hallucination.
///
/// Truy hồi: Postgres full-text search trên `searchable` column (cập nhật
/// qua trigger / raw SQL khi insert), kết hợp ILIKE fallback cho tiếng Việt
/// có dấu. Không dùng vector embedding để giảm phụ thuộc API thứ 3 — corpus
/// nhỏ (~10 PDF sầu riêng) đủ phục vụ qua keyword search.
model KnowledgeChunk {
  id        String   @id @default(cuid())
  source    String   // tên file gốc (vd. "30.6.2025 Quy trình Canh tác sầu riêng.pdf")
  /// Loại cây áp dụng — 'sau-rieng' | 'ca-phe'. Dùng để filter retrieval
  /// trong AI Advisor / Chat để không trộn KB durian với coffee.
  cropType  String   @default("sau-rieng")
  page      Int?     // số trang trong PDF nếu xác định được
  chunkIdx  Int      // thứ tự chunk trong file
  content   String   // nội dung gốc của chunk
  /// Phiên bản không dấu + lowercase để FTS bắt được "thán thư" / "than thu".
  searchable String
  /// Metadata phụ — vd. nếu sau này thêm tag bệnh: { "disease": "anthracnose" }
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([source])
  @@index([cropType])
  @@map("KnowledgeChunks")
}

enum Role {
  ADMIN
  SUPERVISOR
  INVENTORY
  SHIPPER
  CLIENT
}

enum ShipperStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum VehicleType {
  MOTORBIKE
  TRUCK
  VAN
  BICYCLE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum FarmerStatus {
  ACTIVE
  INACTIVE
}

enum PlotStatus {
  ACTIVE
  HARVESTED
  IDLE
  SUSPENDED
  AVAILABLE
  CONTRACTED
}

enum AssignStatus {
  PENDING
  ACTIVE
  DONE
  CANCELLED
}

enum ReportType {
  ROUTINE
  INCIDENT
  HARVEST
}

enum ContractStatus {
  DRAFT
  SIGNED
  REJECTED
  ACTIVE
  EXPIRED
  COMPLETED
  CANCELLED
  SETTLED
  TERMINATED
}

enum QualityGrade {
  STANDARD
  PREMIUM
  A
  B
  C
  REJECT
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  OUT_OF_STOCK
  ARCHIVED
}

enum AddressType {
  HOME
  OFFICE
}

enum PaymentMethod {
  COD
  VNPAY
  MOMO
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum FulfillStatus {
  PENDING
  PACKING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  APPROVED
  REJECTED
}

enum IncidentHandlingStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

enum TransactionType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
  TRANSFER
}

enum TransactionAction {
  RECEIPT
  REJECTION
  GRADE_UPDATE
  WEIGHT_ADJUST
  EXPIRY_UPDATE
  INTERNAL_TRANSFER
  SALE
  OTHER
}

enum InventoryLotStatus {
  SCHEDULED
  ARRIVED
  RECEIVED
  REJECTED
}
