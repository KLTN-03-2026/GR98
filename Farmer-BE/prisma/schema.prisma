// =============================================================================
// schema.prisma — Agri-Integrator
// Nguồn: db.md (2026) + giữ các model đang dùng cho chức năng hiện tại
//
// Stack : Prisma + PostgreSQL
// Auth  : JWT stateless — role + adminId stored in token
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum Role {
  ADMIN
  SUPERVISOR
  CLIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum FarmerStatus {
  ACTIVE
  INACTIVE
}

enum PlotStatus {
  ACTIVE   // đang trồng
  HARVESTED
  IDLE
  SUSPENDED
}

enum AssignStatus {
  PENDING
  ACTIVE
  DONE
  CANCELLED
}

enum ReportType {
  ROUTINE
  INCIDENT
}

enum ContractStatus {
  DRAFT
  SIGNED
  COMPLETED
  CANCELLED
}

enum QualityGrade {
  A
  B
  C
  REJECT
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  OUT_OF_STOCK
  ARCHIVED
}

enum PaymentMethod {
  COD
  VNPAY
  MOMO
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum FulfillStatus {
  PENDING
  PACKING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// =============================================================================
// DOMAIN 0 — AUTH & TOKEN
// =============================================================================

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("RefreshTokens")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("PasswordResets")
}

// Nguồn duy nhất cho authentication (Admin/Supervisor/Client)
// Role được lưu trong JWT — không có Permission table
model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  fullName     String
  phone        String?
  avatar       String?    @db.Text
  role         Role
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  adminProfile      AdminProfile?
  supervisorProfile SupervisorProfile?
  clientProfile     ClientProfile?
  refreshToken      RefreshToken?
  passwordResets    PasswordReset[]

  @@map("users")
}

// =============================================================================
// DOMAIN 1 — USER PROFILES
// =============================================================================

// Profile mở rộng cho ADMIN
// adminId = User.id — dùng làm tenant key trên tất cả bảng khác
model AdminProfile {
  id           String  @id @default(cuid())
  userId       String  @unique
  businessName String
  taxCode      String?
  bankAccount  String?
  province     String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  zones       Zone[]
  supervisors SupervisorProfile[]
  farmers     Farmer[]
  plots       Plot[]
  contracts   Contract[]
  priceBoards PriceBoard[]
  products    Product[]
  orders      Order[]
  assignments Assignment[]
  warehouses  Warehouse[]

  @@map("AdminProfiles")
}

// Profile mở rộng cho SUPERVISOR
// adminId -> biết Supervisor thuộc Admin nào (tenant isolation)
model SupervisorProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  adminId      String // TENANT KEY
  zoneId       String?
  employeeCode String    @unique
  hiredAt      DateTime  @default(now())
  lat          Float? // GPS hiện tại
  lng          Float?
  lastSeenAt   DateTime?

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin AdminProfile @relation(fields: [adminId], references: [id])
  zone  Zone?        @relation(fields: [zoneId], references: [id])

  assignments  Assignment[]
  dailyReports DailyReport[]

  @@map("SupervisorProfiles")
}

// Profile mở rộng cho CLIENT
model ClientProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  adminId        String? // TENANT KEY — multi-tenant buyer
  province       String?
  createdAt      DateTime @default(now())

  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders            Order[]
  reviews           Review[]
  shippingAddresses ClientShippingAddress[]

  @@map("ClientProfiles")
}

// Địa chỉ giao hàng của CLIENT (db.md: clients.shipping_address mở rộng)
model ClientShippingAddress {
  id              String   @id @default(cuid())
  clientProfileId String
  fullName        String
  phone           String
  addressLine     String
  district        String?
  province        String
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([clientProfileId])
  @@map("ClientShippingAddresses")
}

// =============================================================================
// DOMAIN 2 — HRM & BUSINESS AREA (giữ nguyên từ schema cũ)
// =============================================================================

// Khu vực sản xuất — "Business Area" của Admin
model Zone {
  id          String @id @default(cuid())
  adminId     String // TENANT KEY
  name        String
  province    String
  district    String
  centerLat   Float?
  centerLng   Float?
  totalAreaHa Float  @default(0)

  admin       AdminProfile @relation(fields: [adminId], references: [id])
  supervisors SupervisorProfile[]
  plots       Plot[]

  @@map("Zones")
}

// Nông dân ký hợp đồng bao tiêu
model Farmer {
  id          String       @id @default(cuid())
  adminId     String // TENANT KEY
  fullName    String
  phone       String
  cccd        String       @unique // Số CCCD
  bankAccount String?
  address     String?
  province    String?
  status      FarmerStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())

  admin     AdminProfile @relation(fields: [adminId], references: [id])
  plots     Plot[]
  contracts Contract[]

  @@map("Farmers")
}

// Lô đất
model Plot {
  id               String     @id @default(cuid())
  farmerId         String
  adminId          String // TENANT KEY
  zoneId           String?
  plotCode         String     @unique
  cropType         String
  areaHa           Float
  lat              Float?
  lng              Float?
  status           PlotStatus @default(ACTIVE)
  plantingDate     DateTime?
  expectedHarvest  DateTime?
  estimatedYieldKg Float?
  createdAt        DateTime   @default(now())

  farmer Farmer       @relation(fields: [farmerId], references: [id])
  admin  AdminProfile @relation(fields: [adminId], references: [id])
  zone   Zone?        @relation(fields: [zoneId], references: [id])

  assignments  Assignment[]
  dailyReports DailyReport[]
  contracts    Contract[]
  products     Product[]

  @@map("Plots")
}

// Giao việc cho Supervisor
model Assignment {
  id           String       @id @default(cuid())
  supervisorId String
  plotId       String
  adminId      String // TENANT KEY
  status       AssignStatus @default(PENDING)
  assignedAt   DateTime     @default(now())
  dueDate      DateTime?
  note         String?

  supervisor SupervisorProfile @relation(fields: [supervisorId], references: [id])
  plot       Plot              @relation(fields: [plotId], references: [id])
  admin      AdminProfile      @relation(fields: [adminId], references: [id])

  @@map("Assignments")
}

// Báo cáo hàng ngày
model DailyReport {
  id           String     @id @default(cuid())
  supervisorId String
  plotId       String
  adminId      String // TENANT KEY
  type         ReportType @default(ROUTINE)
  content      String
  imageUrls    String[]
  isSynced     Boolean    @default(false)
  reportedAt   DateTime   @default(now())
  syncedAt     DateTime?

  supervisor SupervisorProfile @relation(fields: [supervisorId], references: [id])
  plot       Plot              @relation(fields: [plotId], references: [id])

  @@map("DailyReports")
}

// Bảng giá
model PriceBoard {
  id            String       @id @default(cuid())
  adminId       String // TENANT KEY
  cropType      String
  grade         QualityGrade
  buyPrice      Float
  sellPrice     Float
  effectiveDate DateTime     @default(now())
  isActive      Boolean      @default(true)

  admin     AdminProfile @relation(fields: [adminId], references: [id])
  contracts Contract[]

  @@map("PriceBoards")
}

// =============================================================================
// DOMAIN 3 — CONTRACT & PRODUCT
// =============================================================================

model Contract {
  id           String         @id @default(cuid())
  adminId      String // TENANT KEY
  farmerId     String
  plotId       String
  priceBoardId String?
  contractNo   String         @unique
  cropType     String
  quantityKg   Float
  pricePerKg   Float
  totalAmount  Float
  grade       QualityGrade
  status       ContractStatus @default(DRAFT)
  signedAt     DateTime?
  harvestDue   DateTime?
  signatureUrl String?
  createdAt    DateTime       @default(now())

  admin      AdminProfile @relation(fields: [adminId], references: [id])
  farmer     Farmer       @relation(fields: [farmerId], references: [id])
  plot       Plot         @relation(fields: [plotId], references: [id])
  priceBoard PriceBoard?  @relation(fields: [priceBoardId], references: [id])
  product    Product?

  @@map("Contracts")
}

model Product {
  id                String        @id @default(cuid())
  adminId           String // TENANT KEY
  plotId            String?
  contractId        String?       @unique
  name              String
  slug              String        @unique
  sku               String        @unique
  description       String?
  cropType          String
  grade             QualityGrade
  pricePerKg        Float
  stockKg           Float         @default(0)
  minOrderKg        Float         @default(1)
  unit              String        @default("kg")
  qrCode            String        @unique
  imageUrls         String[]
  thumbnailUrl       String?
  status            ProductStatus @default(DRAFT)
  harvestDate       DateTime?
  aiConfidenceScore Float?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  admin      AdminProfile      @relation(fields: [adminId], references: [id])
  plot       Plot?             @relation(fields: [plotId], references: [id])
  contract   Contract?         @relation(fields: [contractId], references: [id])
  categories ProductCategory[]
  orderItems OrderItem[]
  reviews    Review[]
  transactions WarehouseTransaction[]
  inventoryLots InventoryLot[]

  @@map("Products")
}

// Danh mục sản phẩm — SHARED (không phân tenant)
model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  imageUrl    String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())

  products ProductCategory[]

  @@map("Categories")
}

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("ProductCategories")
}

// =============================================================================
// DOMAIN 4 — E-COMMERCE (CLIENT)
// =============================================================================

// Order dùng ClientProfile (User+ClientProfile) — không cần bảng Client riêng
model Order {
  id              String        @id @default(cuid())
  clientId        String
  adminId         String // TENANT KEY
  orderNo         String        @unique
  orderCode       String        @unique // mã hiển thị: ĐH-20260409-001
  subtotal        Float
  shippingFee     Float         @default(0)
  discount        Float         @default(0)
  total           Float
  paymentMethod   PaymentMethod
  paymentRef      String?
  paymentStatus   PaymentStatus @default(PENDING)
  fulfillStatus   FulfillStatus @default(PENDING)
  shippingAddr    Json // { fullName, phone, addressLine, district, province }
  shippingAddrText String?      @db.Text // địa chỉ dạng text đơn giản
  trackingCode    String?
  note            String?
  orderedAt       DateTime      @default(now())
  paidAt          DateTime?

  client ClientProfile @relation(fields: [clientId], references: [id])
  admin  AdminProfile  @relation(fields: [adminId], references: [id])
  orderItems OrderItem[]

  @@map("Orders")
}

model OrderItem {
  id            String @id @default(cuid())
  orderId       String
  productId     String
  nameSnapshot  String
  priceSnapshot Float
  quantityKg    Float
  subtotal      Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("OrderItems")
}

model Review {
  id               String       @id @default(cuid())
  productId        String
  clientId         String
  rating           Int
  comment          String?      @db.Text
  imageUrls        String[]
  verifiedPurchase Boolean      @default(false)
  status           ReviewStatus @default(PENDING)
  createdAt        DateTime     @default(now())

  product Product       @relation(fields: [productId], references: [id])
  client  ClientProfile @relation(fields: [clientId], references: [id])

  @@map("Reviews")
}

// =============================================================================
// DOMAIN 5 — WAREHOUSE & INVENTORY (từ db.md)
// =============================================================================

// Kho hàng
model Warehouse {
  id             String  @id @default(cuid())
  name           String
  locationAddress String? @db.Text
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())

  managedBy String
  admin     AdminProfile        @relation(fields: [managedBy], references: [id])
  inventoryLots InventoryLot[]
  transactions  WarehouseTransaction[]

  @@map("warehouses")
}

// Lô hàng nhập kho
model InventoryLot {
  id              String   @id @default(cuid())
  warehouseId     String
  productId       String
  contractId      String? // nguồn truy xuất nếu có
  quantityKg      Float
  harvestDate     DateTime?
  expiryDate      DateTime?
  qualityGrade    QualityGrade
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  warehouse     Warehouse             @relation(fields: [warehouseId], references: [id])
  product       Product               @relation(fields: [productId], references: [id])
  transactions  WarehouseTransaction[]

  @@map("inventory_lots")
}

// Log xuất/nhập/điều chỉnh kho (append-only)
model WarehouseTransaction {
  id              String   @id @default(cuid())
  warehouseId     String
  productId       String
  inventoryLotId  String
  type            String   // inbound | outbound | adjustment
  quantityKg      Float
  note            String?  @db.Text
  createdBy       String
  createdAt       DateTime @default(now())

  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  inventoryLot InventoryLot @relation(fields: [inventoryLotId], references: [id])

  @@map("warehouse_transactions")
}
