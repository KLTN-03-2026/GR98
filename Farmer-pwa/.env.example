# =============================================================================
# Agri Supervisor PWA - Environment Configuration
# =============================================================================
# Copy file nay thanh .env va thay doi gia tri theo moi truong

# Backend API (agri-main)
# Local dev: http://localhost:3000
# Production: https://api.your-domain.com
VITE_API_BASE_URL=http://localhost:3000

# AI Vision API (FastAPI service)
# Local dev: http://localhost:8000
# Production: https://ai-vision.your-domain.com
VITE_AI_VISION_API_URL=http://localhost:8000 (ipconfig để tìm IP máy tính)