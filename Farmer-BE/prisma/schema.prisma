generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("RefreshTokens")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("PasswordResets")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  passwordHash      String
  fullName          String
  phone             String?
  avatar            String?
  role              Role
  status            UserStatus         @default(ACTIVE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  adminProfile      AdminProfile?
  clientProfile     ClientProfile?
  inventoryProfile  InventoryProfile?
  passwordResets    PasswordReset[]
  refreshToken      RefreshToken?
  supervisorProfile SupervisorProfile?

  @@map("users")
}

model AdminProfile {
  id               String              @id @default(cuid())
  userId           String              @unique
  businessName     String
  taxCode          String?
  bankAccount      String?
  province         String
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments      Assignment[]
  contracts        Contract[]
  farmers          Farmer[]
  inventoryStaff   InventoryProfile[]
  orders           Order[]
  plantScanRecords PlantScanRecord[]
  plots            Plot[]
  priceBoards      PriceBoard[]
  products         Product[]
  supervisors      SupervisorProfile[]
  zones            Zone[]
  warehouses       Warehouse[]

  @@map("AdminProfiles")
}

model InventoryProfile {
  id           String       @id @default(cuid())
  userId       String       @unique
  adminId      String
  employeeCode String       @unique
  hiredAt      DateTime     @default(now())
  admin        AdminProfile @relation(fields: [adminId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouses   Warehouse[]

  @@map("InventoryProfiles")
}

model SupervisorProfile {
  id               String            @id @default(cuid())
  userId           String            @unique
  adminId          String
  zoneId           String?
  employeeCode     String            @unique
  hiredAt          DateTime          @default(now())
  lat              Float?
  lng              Float?
  lastSeenAt       DateTime?
  assignments      Assignment[]
  contracts        Contract[]
  dailyReports     DailyReport[]
  farmers          Farmer[]
  plantScanRecords PlantScanRecord[]
  admin            AdminProfile      @relation(fields: [adminId], references: [id])
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  zone             Zone?             @relation(fields: [zoneId], references: [id])

  @@map("SupervisorProfiles")
}

model ClientProfile {
  id                String                  @id @default(cuid())
  userId            String                  @unique
  adminId           String?
  province          String?
  createdAt         DateTime                @default(now())
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingAddresses ClientShippingAddress[]
  orders            Order[]
  reviews           Review[]

  @@map("ClientProfiles")
}

model ClientShippingAddress {
  id              String        @id @default(cuid())
  clientProfileId String
  fullName        String
  phone           String
  addressLine     String
  district        String?
  province        String
  isDefault       Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([clientProfileId])
  @@map("ClientShippingAddresses")
}

model Zone {
  id          String              @id @default(cuid())
  adminId     String
  name        String
  province    String
  district    String
  centerLat   Float?
  centerLng   Float?
  totalAreaHa Float               @default(0)
  plots       Plot[]
  supervisors SupervisorProfile[]
  admin       AdminProfile        @relation(fields: [adminId], references: [id])

  @@map("Zones")
}

model Farmer {
  id           String             @id @default(cuid())
  adminId      String
  fullName     String
  phone        String
  cccd         String             @unique
  bankAccount  String?
  bankName     String?
  bankBranch   String?
  address      String?
  province     String?
  status       FarmerStatus       @default(ACTIVE)
  createdAt    DateTime           @default(now())
  supervisorId String?
  contracts    Contract[]
  admin        AdminProfile       @relation(fields: [adminId], references: [id])
  supervisor   SupervisorProfile? @relation(fields: [supervisorId], references: [id])
  plots        Plot[]

  @@map("Farmers")
}

model Plot {
  id               String            @id @default(cuid())
  farmerId         String
  adminId          String
  zoneId           String?
  plotCode         String            @unique
  cropType         String
  areaHa           Float
  lat              Float?
  lng              Float?
  status           PlotStatus        @default(ACTIVE)
  plantingDate     DateTime?
  expectedHarvest  DateTime?
  estimatedYieldKg Float?
  createdAt        DateTime          @default(now())
  assignments      Assignment[]
  contracts        Contract[]
  dailyReports     DailyReport[]
  plantScanRecords PlantScanRecord[]
  admin            AdminProfile      @relation(fields: [adminId], references: [id])
  farmer           Farmer            @relation(fields: [farmerId], references: [id])
  zone             Zone?             @relation(fields: [zoneId], references: [id])
  products         Product[]

  @@map("Plots")
}

model Assignment {
  id           String            @id @default(cuid())
  supervisorId String
  plotId       String
  adminId      String
  status       AssignStatus      @default(PENDING)
  assignedAt   DateTime          @default(now())
  dueDate      DateTime?
  note         String?
  admin        AdminProfile      @relation(fields: [adminId], references: [id])
  plot         Plot              @relation(fields: [plotId], references: [id])
  supervisor   SupervisorProfile @relation(fields: [supervisorId], references: [id])

  @@map("Assignments")
}

model DailyReport {
  id              String            @id @default(cuid())
  supervisorId    String
  plotId          String
  adminId         String
  type            ReportType        @default(ROUTINE)
  content         String
  imageUrls       String[]
  isSynced        Boolean           @default(false)
  reportedAt      DateTime          @default(now())
  syncedAt        DateTime?
  status          ReportStatus      @default(DRAFT)
  aiVisionResult  Json?
  yieldEstimateKg Float?
  plot            Plot              @relation(fields: [plotId], references: [id])
  supervisor      SupervisorProfile @relation(fields: [supervisorId], references: [id])

  @@map("DailyReports")
}

model PriceBoard {
  id            String       @id @default(cuid())
  adminId       String
  cropType      String
  grade         QualityGrade
  buyPrice      Float
  sellPrice     Float
  effectiveDate DateTime     @default(now())
  isActive      Boolean      @default(true)
  admin         AdminProfile @relation(fields: [adminId], references: [id])

  @@map("PriceBoards")
}

model Contract {
  id                       String            @id @default(cuid())
  adminId                  String
  supervisorId             String
  farmerId                 String
  plotId                   String?
  contractNo               String            @unique
  cropType                 String
  grade                    QualityGrade
  status                   ContractStatus    @default(DRAFT)
  signedAt                 DateTime?
  harvestDue               DateTime?
  signatureUrl             String?
  traceabilityQr           String?
  submittedAt              DateTime?
  approvedAt               DateTime?
  approvedBy               String?
  rejectedReason           String?
  plotDraftProvince        String?
  plotDraftDistrict        String?
  plotDraftAreaHa          Float?
  plotDraftCoordinatesText String?
  createdAt                DateTime          @default(now())
  admin                    AdminProfile      @relation(fields: [adminId], references: [id])
  farmer                   Farmer            @relation(fields: [farmerId], references: [id])
  plot                     Plot?             @relation(fields: [plotId], references: [id])
  supervisor               SupervisorProfile @relation(fields: [supervisorId], references: [id])
  product                  Product?
  inventoryLots            InventoryLot[]

  @@map("Contracts")
}

model Product {
  id                String                 @id @default(cuid())
  adminId           String
  plotId            String?
  contractId        String?                @unique
  name              String
  slug              String                 @unique
  sku               String                 @unique
  description       String?
  cropType          String
  grade             QualityGrade
  pricePerKg        Float
  stockKg           Float                  @default(0)
  minOrderKg        Float                  @default(1)
  unit              String                 @default("kg")
  qrCode            String                 @unique
  imageUrls         String[]
  thumbnailUrl      String?
  status            ProductStatus          @default(DRAFT)
  harvestDate       DateTime?
  aiConfidenceScore Float?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  orderItems        OrderItem[]
  categories        ProductCategory[]
  admin             AdminProfile           @relation(fields: [adminId], references: [id])
  contract          Contract?              @relation(fields: [contractId], references: [id])
  plot              Plot?                  @relation(fields: [plotId], references: [id])
  reviews           Review[]
  inventoryLots     InventoryLot[]
  transactions      WarehouseTransaction[]

  @@map("Products")
}

model Category {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  imageUrl    String?
  isActive    Boolean           @default(true)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  products    ProductCategory[]

  @@map("Categories")
}

model ProductCategory {
  productId  String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("ProductCategories")
}

model Order {
  id               String        @id @default(cuid())
  clientId         String
  adminId          String
  orderNo          String        @unique
  orderCode        String        @unique
  subtotal         Float
  shippingFee      Float         @default(0)
  discount         Float         @default(0)
  total            Float
  paymentMethod    PaymentMethod
  paymentRef       String?
  paymentStatus    PaymentStatus @default(PENDING)
  fulfillStatus    FulfillStatus @default(PENDING)
  shippingAddr     Json
  shippingAddrText String?
  trackingCode     String?
  note             String?
  orderedAt        DateTime      @default(now())
  paidAt           DateTime?
  orderItems       OrderItem[]
  admin            AdminProfile  @relation(fields: [adminId], references: [id])
  client           ClientProfile @relation(fields: [clientId], references: [id])

  @@map("Orders")
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  productId     String
  nameSnapshot  String
  priceSnapshot Float
  quantityKg    Float
  subtotal      Float
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product @relation(fields: [productId], references: [id])

  @@map("OrderItems")
}

model Review {
  id               String        @id @default(cuid())
  productId        String
  clientId         String
  rating           Int
  comment          String?
  imageUrls        String[]
  verifiedPurchase Boolean       @default(false)
  status           ReviewStatus  @default(PENDING)
  createdAt        DateTime      @default(now())
  client           ClientProfile @relation(fields: [clientId], references: [id])
  product          Product       @relation(fields: [productId], references: [id])

  @@map("Reviews")
}

model Warehouse {
  id              String                 @id @default(cuid())
  name            String
  locationAddress String?
  isActive        Boolean                @default(true)
  createdAt       DateTime               @default(now())
  managedBy       String?
  adminId         String
  inventoryLots   InventoryLot[]
  transactions    WarehouseTransaction[]
  admin           AdminProfile           @relation(fields: [adminId], references: [id])
  inventory       InventoryProfile?      @relation(fields: [managedBy], references: [id])

  @@map("warehouses")
}

model InventoryLot {
  id           String                 @id @default(cuid())
  warehouseId  String
  productId    String
  contractId   String?
  quantityKg   Float
  harvestDate  DateTime?
  expiryDate   DateTime?
  qualityGrade QualityGrade
  status         InventoryLotStatus     @default(SCHEDULED)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  contract     Contract?              @relation(fields: [contractId], references: [id])
  product      Product                @relation(fields: [productId], references: [id])
  warehouse    Warehouse              @relation(fields: [warehouseId], references: [id])
  transactions WarehouseTransaction[]

  @@map("inventory_lots")
}

enum InventoryLotStatus {
  SCHEDULED    // Hàng sắp về (tương lai)
  ARRIVED      // Chờ nhập kho (đã đến ngày nhưng chưa xác nhận)
  RECEIVED     // Đã vào kho (đã có transaction)
  REJECTED     // Bị từ chối
}

model WarehouseTransaction {
  id             String            @id @default(cuid())
  warehouseId    String
  productId      String
  inventoryLotId String
  type           TransactionType   // Loại chính (INBOUND, OUTBOUND, ADJUSTMENT, TRANSFER)
  action         TransactionAction // Hành động chi tiết (RECEIPT, REJECTION, ...)
  quantityKg     Float
  note           String?
  createdBy      String
  createdAt      DateTime          @default(now())
  inventoryLot   InventoryLot      @relation(fields: [inventoryLotId], references: [id])
  product        Product           @relation(fields: [productId], references: [id])
  warehouse      Warehouse         @relation(fields: [warehouseId], references: [id])

  @@map("warehouse_transactions")
}

enum TransactionType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
  TRANSFER
}

enum TransactionAction {
  RECEIPT
  REJECTION
  GRADE_UPDATE
  WEIGHT_ADJUST
  EXPIRY_UPDATE
  INTERNAL_TRANSFER
  SALE
  OTHER
}

model PlantScanRecord {
  id           String            @id @default(uuid())
  adminId      String
  supervisorId String
  plotId       String?
  diseaseEn    String
  diseaseVi    String
  causingAgent String
  dangerLevel  String
  category     String
  symptoms     String
  treatment    String
  confidence   Float
  processingMs Float?
  imageDataUrl String?
  scannedAt    DateTime          @default(now())
  admin        AdminProfile      @relation(fields: [adminId], references: [id])
  plot         Plot?             @relation(fields: [plotId], references: [id])
  supervisor   SupervisorProfile @relation(fields: [supervisorId], references: [id])

  @@index([adminId])
  @@index([supervisorId])
  @@index([scannedAt])
  @@map("PlantScanRecords")
}

enum Role {
  ADMIN
  SUPERVISOR
  INVENTORY
  CLIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum FarmerStatus {
  ACTIVE
  INACTIVE
}

enum PlotStatus {
  ACTIVE
  HARVESTED
  IDLE
  SUSPENDED
  AVAILABLE
  CONTRACTED
}

enum AssignStatus {
  PENDING
  ACTIVE
  DONE
  CANCELLED
}

enum ReportType {
  ROUTINE
  INCIDENT
}

enum ContractStatus {
  DRAFT
  SIGNED
  REJECTED
  ACTIVE
  EXPIRED
  COMPLETED
  CANCELLED
  SETTLED
  TERMINATED
}

enum QualityGrade {
  A
  B
  C
  REJECT
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  OUT_OF_STOCK
  ARCHIVED
}

enum PaymentMethod {
  COD
  VNPAY
  MOMO
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum FulfillStatus {
  PENDING
  PACKING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}
