# ── Detector (YOLOv8 — train with scripts/train_yolo_detection.py)
DEVICE=cpu
DETECTOR_MODEL_PATH=ai/weights/durian_leaf_detector.pt
DETECTOR_LABELS_PATH=ai/weights/durian_leaf_detector.json

# ── Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=info

# ── Paths
UPLOAD_DIR=/tmp/uploads
OUTPUT_DIR=/tmp/outputs

# ── CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
